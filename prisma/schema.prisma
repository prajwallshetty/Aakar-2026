generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Participant {
  id                    Int           @id @default(autoincrement())
  uuid                  String        @unique @default(uuid())
  name                  String
  usn                   String        @unique
  phone                 String
  college               String
  transaction_ids       String[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  email                 String        @unique
  paymentScreenshotUrls String[]
  paymentStatus         PaymentStatus @default(PENDING)
  certificateSent       Boolean       @default(false)
  certificateId         String?       @unique
  department            String?
  amount                Int           @default(0)
  year                  Int           @default(1)
  groupMembersData      Json?         @default("[]")
  events                Event[]       @relation("EventToParticipant")
}

model Event {
  id                  Int           @id @default(autoincrement())
  eventName           String
  eventCategory       eventCategory @default(Technical)
  eventType           eventType     @default(Solo)
  minMembers          Int           @default(1)
  maxMembers          Int           @default(1)
  description         String
  fee                 Int
  date                DateTime
  time                String
  venue               String
  studentCoordinators Json          @default("[]")
  facultyCoordinators Json          @default("[]")
  rules               String[]
  imageUrl            String
  Participants        Participant[] @relation("EventToParticipant")
}

model Admin {
  id       Int    @id @default(autoincrement())
  name     String
  phone    String @unique
  password String
  email    String @unique
}

model MerchOrder {
  id                   Int        @id @default(autoincrement())
  uuid                 String     @unique @default(uuid())
  name                 String
  email                String     @unique
  phone                String
  size                 tshirtSize
  transactionId        String     @unique
  amount               Int        @default(499)
  paymentScreenshotUrl String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model ElitePassOrder {
  id                   Int      @id @default(autoincrement())
  uuid                 String   @unique @default(uuid())
  name                 String
  usn                  String   @unique
  email                String   @unique
  phone                String
  college              String
  department           String?
  year                 Int      @default(1)
  transactionId        String   @unique
  amount               Int      @default(0)
  paymentScreenshotUrl String?
  paymentStatus        PaymentStatus @default(PENDING)
  certificateSent      Boolean       @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt
}

enum PaymentStatus {
  PENDING
  APPROVED
  FAILED
}

enum eventCategory {
  Technical
  Cultural
  Gaming
  Special
  ComboPass
}

enum eventType {
  Solo
  Team
}

enum tshirtSize {
  XS
  S
  M
  L
  XL
  XXL
  XXXL
  XXXXL
}
